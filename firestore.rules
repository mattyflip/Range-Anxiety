rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper to check if the user owns the document (for user profiles)
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // --- Users Collection ---
    match /users/{userId} {
      // Allow reading basic info for social features, but restrict sensitive fields
      // NOTE: Granular field-level security can be added here if needed
      allow read: if isSignedIn(); 
      allow write: if isOwner(userId);
    }

    // --- Community Feed ---
    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (request.auth.uid == resource.data.authorId || request.auth.token.email == 'mattyfliptv@gmail.com');
      
      // Post Comments
      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn() && (request.auth.uid == resource.data.authorId || request.auth.token.email == 'mattyfliptv@gmail.com');
      }
    }

    // --- Forum Hub ---
    match /communities/{communityId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (request.auth.uid == resource.data.creatorId || request.auth.token.email == 'mattyfliptv@gmail.com');

      // Threads within a community
      match /threads/{threadId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn() && (request.auth.uid == resource.data.authorId || request.auth.token.email == 'mattyfliptv@gmail.com');

        // Comments within a thread
        match /comments/{commentId} {
          allow read: if isSignedIn();
          allow create: if isSignedIn();
          allow update, delete: if isSignedIn() && (request.auth.uid == resource.data.authorId || request.auth.token.email == 'mattyfliptv@gmail.com');
        }
      }
    }

    // --- Social Interactions ---
    match /followers/{followId} {
      // ID format is usually "followerId_followingId"
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == request.resource.data.followerId;
      allow delete: if isSignedIn() && request.auth.uid == resource.data.followerId;
    }

    match /user_reviews/{reviewId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.authorId;
      allow update, delete: if isSignedIn() && (request.auth.uid == resource.data.authorId || request.auth.token.email == 'mattyfliptv@gmail.com');
    }

    // --- Group Rides Collection ---
    match /group_rides/{rideId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (request.auth.uid == resource.data.creatorId || request.auth.token.email == 'mattyfliptv@gmail.com');
      
      match /participants/{participantId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && request.auth.uid == participantId;
        allow delete: if isSignedIn() && (request.auth.uid == participantId || request.auth.uid == get(/databases/$(database)/documents/group_rides/$(rideId)).data.creatorId);
      }
    }

    // --- System Status & Marketing ---
    match /system/status {
      allow read: if true;
      allow write: if request.auth.token.email == 'mattyfliptv@gmail.com';
    }

    match /marketing_emails/{docId} {
      allow create: if true;
      allow read, update, delete: if false;
    }
    
    match /bike_submissions/{docId} {
      allow create: if isSignedIn();
      allow read, update, delete: if false;
    }
  }
}

